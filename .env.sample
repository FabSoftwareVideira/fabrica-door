# Configurações gerais
SITE_NAME="Fábrica de Software - IFC Videira"
SITE_URL=

# Outras configurações
EMAIL_FABRICA=fabricadesoftware.videira@ifc.edu.br
GOOGLE_ANALYTICS=
API_KEY=chave_de_api_do_servico_de_email

# Configurações de rede e container
PORT=8000
ENVIRONMENT=development
NODE_ENV=development
LOG_LEVEL=DEBUG

# Configurações do deploy (do deploy.sh)
GITHUB_URL=https://github.com/fabricioifc/fabrica-door.git
PROJECT_NAME=fabrica-prod-door
NETWORK_NAME=fabrica-door-network
NETWORK_NAME_NGINX=fabrica-nginx-proxy-network
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_COMPOSE_BUILD=true
BRANCH=main
LOG_FILE=deploy.log

# ----------------------------------------------------------------
# Banco de dados PostgreSQL
# ----------------------------------------------------------------
PGHOST=db
PGPORT=5432
PGDATABASE=fabrica_door
PGUSER=postgres
PGPASSWORD=postgres
# Descomente para SSL em produção:
# PGSSLMODE=require

# ----------------------------------------------------------------
# Autenticação JWT
# ----------------------------------------------------------------
# Gere um segredo forte em produção, ex: openssl rand -hex 64
JWT_SECRET=mude_em_producao_use_um_valor_secreto_longo
JWT_EXPIRES_IN=8h
